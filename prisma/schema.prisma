generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

model accounts {
  account_id   String         @id(map: "pk_accounts") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type         Tipo?          @default(BANK)
  balance      Decimal        @default(0) @db.Decimal(10, 2)
  color        String?        @db.VarChar(7)
  user_id      String         @db.Uuid
  user         user           @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "user_accounts")
  transactions transactions[]
}

model categories {
  id           Int            @id(map: "pk_categories") @default(autoincrement())
  name         String         @db.VarChar(100)
  color        String?        @db.VarChar(7)
  icon         String?        @db.VarChar(100)
  user_id      String         @db.Uuid
  user         user           @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_categories")
  transactions transactions[]
}

model transactions {
  trans_id    String      @id(map: "pk_transactions") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String      @db.VarChar(150)
  amount      Decimal     @db.Decimal(10, 2)
  type        Amount
  date        DateTime    @db.Date
  notes       String?
  account_id  String      @db.Uuid
  category_id Int?
  created_at  DateTime?   @default(now()) @db.Timestamp(6)
  updated_at  DateTime?   @default(now()) @db.Timestamp(6)
  accounts    accounts    @relation(fields: [account_id], references: [account_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_account_transactions")
  categories  categories? @relation(fields: [category_id], references: [id], onUpdate: NoAction, map: "fk_category_transactions")
}

model user {
  user_id    String       @id(map: "pk_user") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username   String       @db.VarChar(100)
  email      String       @unique(map: "unique_user") @db.VarChar(150)
  password   String       @db.VarChar(255)
  accounts   accounts[]
  categories categories[]
}

enum Amount {
  INCOME
  EXPENSE
}

enum Tipo {
  WALLET
  BANK
  CREDIT_CARD
}
